{
  "expo": {
    "name": "Mahjong Aura",
    "slug": "mahjong-aura",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mahjong_aura_logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/mahjong_aura_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#334443"
    },
    "locales": {
      "en": "./locales/en.json",
      "tr": "./locales/tr.json",
      "zh-Hans": "./locales/zh-Hans.json",
      "es": "./locales/es.json",
      "fr": "./locales/fr.json",
      "de": "./locales/de.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mahjongaura.app",
      "backgroundColor": "#334443",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "en",
          "tr",
          "zh-Hans",
          "es",
          "fr",
          "de"
        ]
      }
    },
    "android": {
      "package": "com.mahjongaura.app",
      "adaptiveIcon": {
        "backgroundColor": "#334443",
        "foregroundImage": "./assets/mahjong_aura_logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/mahjong_aura_logo.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
